{
  "manifest_version": 3,
  "name": "TVABDOU - Live Tracker",
  "version": "1.4.0",
  "key": "",
  "description": "Savoir si TVABDOU est en live, voir la derniere VOD, le planning, les dernieres videos et recevoir des notifications.",
  "permissions": [
    "storage",
    "notifications",
    "alarms"
  ],
  "host_permissions": [
    "https://*.vercel.app/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "TVABDOU",
    "default_icon": {
      "16": "icons/off-16.png",
      "32": "icons/off-32.png",
      "48": "icons/off-48.png",
      "128": "icons/off-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; frame-src https://planning-live.vercel.app https://*.vercel.app;"
  }
}
